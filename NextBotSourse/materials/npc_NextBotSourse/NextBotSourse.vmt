"UnlitGeneric"
{
   "$basetexture" "npc_NextBotSourse/NextBotSourse"
  "$translucent" 1
  "$vertexalpha" 1
   "Proxies"
   {
      "AnimatedTexture"
      {
         "animatedtexturevar" "$basetexture"
         "animatedtextureframenumvar" "$frame"
         "animatedtextureframerate" "1"
      }
   }
}